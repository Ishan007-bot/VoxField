# Copy this file to ".env" and configure ONE of the two AI options below.
# If neither is set, the app still works using the rule-based fallback
# (lower quality, English-tuned), so a key is optional but recommended.

# ── Option 1: AI Studio API key (simplest, free tier) ──────────────────
# Get one at https://aistudio.google.com -> "Get API key"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Option 2: Vertex AI via a GCP service-account (paid, no rate limits) ─
# Used for Gemini AND Google Cloud Speech-to-Text / Text-to-Speech.
# 1. Put your service-account JSON at backend/gcp-credentials.json
# 2. Set the path + region below. Project ID is read from the JSON.
GOOGLE_APPLICATION_CREDENTIALS=gcp-credentials.json
USE_VERTEX=false                 # set true to use Vertex AI for the LLM
VERTEX_LOCATION=us-central1      # e.g. us-central1, asia-south1
VERTEX_MODEL=gemini-2.5-flash

# Cloud STT/TTS (Step 2) — used only when online; browser used offline.
USE_CLOUD_SPEECH=false           # set true to enable Cloud STT/TTS endpoints
