# Copy this file to ".env" and paste your real key in.
# Get a free key at https://aistudio.google.com  ->  "Get API key"
# The app works WITHOUT a key too (it falls back to rule-based extraction/Q&A),
# but Gemini gives much better quality and full multi-language support.

GEMINI_API_KEY=

# Model to use (free-tier friendly). Leave as-is unless you know you want another.
GEMINI_MODEL=gemini-2.0-flash
